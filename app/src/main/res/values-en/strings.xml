    <!-- Terms of Service -->
    <string name="terms_effective_date">Effective: January 1, 2025</string>
    <string name="terms_intro">These Terms of Service govern your use of D.log, provided by the Sangmyung University Capstone Team ("the Team"). By using the Service, you agree to these Terms.</string>
    <string name="terms_s1_title">Article 1 (Purpose)</string>
    <string name="terms_s1_body">These Terms define the conditions of use for the D.log smart diary service and the rights and responsibilities of both the Team and users.</string>
    <string name="terms_s2_title">Article 2 (Eligibility)</string>
    <string name="terms_s2_body">• Available to users aged 14 and older\n• Requires Google account or email registration\n• Service is provided only to users who agree to these Terms</string>
    <string name="terms_s3_title">Article 3 (Service Content)</string>
    <string name="terms_s3_body">• Personal diary creation, storage, and retrieval\n• Auto-draft generation from weather, schedule, and photos\n• Diary writing reminders via push notifications\n• Service requires an active internet connection.</string>
    <string name="terms_s4_title">Article 4 (Prohibited Activities)</string>
    <string name="terms_s4_body">Users must not engage in the following:\n• Impersonating or accessing other users\' accounts\n• Disrupting service operations\n• Storing illegal or harmful content\n• Reverse engineering or redistributing the app</string>
    <string name="terms_s5_title">Article 5 (Disclaimer)</string>
    <string name="terms_s5_body">• We are not liable for service interruptions due to natural disasters or technical failures.\n• We are not responsible for data loss caused by user actions.\n• This app is an academic graduation project.</string>
    <string name="terms_s6_title">Article 6 (Changes to Terms)</string>
    <string name="terms_s6_body">Changes to these Terms will be announced in-app at least 7 days in advance. Continued use after changes indicates acceptance of the updated Terms.</string>
