    <!-- Privacy Policy -->
    <string name="privacy_effective_date">Effective: January 1, 2025</string>
    <string name="privacy_intro">D.log ("the App") values your privacy. This Privacy Policy explains how we handle your personal information in accordance with applicable laws. The App is an academic capstone project developed by Sangmyung University.</string>
    <string name="privacy_s1_title">1. Information We Collect</string>
    <string name="privacy_s1_body">• Email address, password (encrypted)\n• Google account: name, email, profile photo\n• Diary content, creation date\n• Weather, mood, and schedule data\n• Attached photos (stored in Firebase)</string>
    <string name="privacy_s2_title">2. Purpose of Collection</string>
    <string name="privacy_s2_body">• User identification and authentication\n• Diary data storage and sync\n• Auto-draft generation from weather and schedule\n• Service improvement and error analysis</string>
    <string name="privacy_s3_title">3. Retention Period</string>
    <string name="privacy_s3_body">All personal data and diary entries are immediately deleted upon account deletion. Data stored in Firebase Firestore is removed during deletion, and no separate backup is retained.</string>
    <string name="privacy_s4_title">4. Third-Party Sharing</string>
    <string name="privacy_s4_body">We do not share your personal information with third parties. However, we use Firebase (Google LLC) as our backend infrastructure, and Google\'s separate privacy policy applies.</string>
    <string name="privacy_s5_title">5. Your Rights</string>
    <string name="privacy_s5_body">• You may request access, correction, or deletion of your data at any time\n• Delete your data instantly via Delete Account in the app\n• Contact: capstone@smu.ac.kr</string>
    <string name="privacy_s6_title">6. Privacy Contact</string>
    <string name="privacy_s6_body">Team: Sangmyung University Capstone\nEmail: capstone@smu.ac.kr\nApp Version: 1.0</string>

