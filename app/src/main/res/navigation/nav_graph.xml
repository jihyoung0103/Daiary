<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.capstone_login.ui.auth.LoginFragment"
        android:label="로그인"
        tools:layout="@layout/fragment_login">

        <!-- Navigation action to CalendarFragment.
             Phase 2/3: use this action ID when navigating on AuthUiState.Success.
             Phase 3: add popUpTo="@id/loginFragment" inclusive="true" as NavOptions. -->
        <action
            android:id="@+id/action_loginFragment_to_calendarFragment"
            app:destination="@id/calendarFragment" />

    </fragment>

    <fragment
        android:id="@+id/calendarFragment"
        android:name="com.example.capstone_login.ui.calendar.CalendarFragment"
        android:label="캘린더"
        tools:layout="@layout/fragment_calendar" />

</navigation>
